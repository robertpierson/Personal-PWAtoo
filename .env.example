# Supabase — absent values put the app in demo mode.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Force the demo workspace even when Supabase is configured (1 = demo).
NEXT_PUBLIC_FORCE_DEMO=

# Google OAuth (configured in Supabase Auth → Providers → Google)
GOOGLE_CLIENT_ID=

# Stripe Payment Links (create in Stripe dashboard -> Payment Links,
# one per tier; yearly variants can live inside the same link).
# Empty = pricing CTAs fall back to /contact.
NEXT_PUBLIC_STRIPE_LINK_STARTER=
NEXT_PUBLIC_STRIPE_LINK_CHAPTER=
NEXT_PUBLIC_STRIPE_LINK_FOUNDER=
